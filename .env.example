# =============================================================================
# .env.example — node-token Docker Compose 环境变量模板
#
# ⚠️ 适用范围说明
#   此文件仅适用于 Docker Compose 部署（docker compose up -d）。
#   二进制直接启动（./target/release/node-token）不读取 .env 文件，
#   请使用 config.toml 或环境变量 NODE_TOKEN__* 进行配置。
#
# 使用方法：
#   cp .env.example .env
#   # 编辑 .env 填入实际值（特别是 NODE_TOKEN__REGISTRATION_TOKEN）
#   docker compose up -d
#
# 所有以 NODE_TOKEN__ 为前缀的变量会覆盖 config.toml 中的对应配置。
# 不设值的变量会使用 docker-compose.yml 中定义的默认值。
# =============================================================================

# ═══════════════════════════════════════════════════════════════════════════
# Node-token 必需配置
# ═══════════════════════════════════════════════════════════════════════════

# KeyCompute 注册 token（必需！从 KeyCompute 服务端配置获取）
# 对应 config.toml: registration_token
# 从 KeyCompute 服务端 node_gateway.registration_token 配置获取
NODE_TOKEN__REGISTRATION_TOKEN=change-me-in-production

# ═══════════════════════════════════════════════════════════════════════════
# Node-token 可选配置
# ═══════════════════════════════════════════════════════════════════════════

# KeyCompute 服务端 URL（可选，默认 http://localhost:3000）
# 对应 config.toml: server_url
# 在 Docker Compose 环境中通常使用 http://keycompute-server:3000
# NODE_TOKEN__SERVER_URL=http://keycompute-server:3000

# 节点显示名称（可选，默认 My PC Node）
# 对应 config.toml: display_name
# NODE_TOKEN__DISPLAY_NAME=My PC Node

# Ollama API 地址（可选，默认 http://ollama:11434）
# 在 Docker Compose 中通过服务名 ollama 访问
# 对应 config.toml: ollama_url
# NODE_TOKEN__OLLAMA_URL=http://ollama:11434

# 心跳间隔（秒，可选，默认 30）
# 对应 config.toml: heartbeat_interval_secs
# NODE_TOKEN__HEARTBEAT_INTERVAL_SECS=30

# Excluded 节点 poll 检查间隔（秒，可选，默认 30）
# 对应 config.toml: excluded_poll_check_interval_secs
# NODE_TOKEN__EXCLUDED_POLL_CHECK_INTERVAL_SECS=30

# 最大并发任务数（可选，默认 2）
# 控制同时执行的任务数量，防止过多任务并发导致资源耗尽
# 对应 config.toml: max_concurrent_tasks
# NODE_TOKEN__MAX_CONCURRENT_TASKS=2

# 本地数据目录（可选，Docker 环境默认 /data，二进制启动默认 ~/.local/share/node-token）
# 对应 config.toml: data_dir
# NODE_TOKEN__DATA_DIR=/data

# ═══════════════════════════════════════════════════════════════════════════
# Ollama 配置
# ═══════════════════════════════════════════════════════════════════════════

# 模型在内存中的保活时间（可选，默认 30m）
# 设置为 -1 表示常驻内存
OLLAMA_KEEP_ALIVE=30m

# Ollama API 对外端口映射（可选，默认 11434）
# OLLAMA_PORT=11434

# 容器启动后自动拉取并预热的模型名称（可选，默认 gemma3:270m）
# ollama-model-init 服务会拉取此模型并执行一次简单预热推理
OLLAMA_MODEL=gemma3:270m

# 预热模型时发送的简短提示词（可选，默认 ready）
# 预热推理会让模型加载到内存中，减少首次请求的响应延迟
OLLAMA_WARMUP_PROMPT=ready
